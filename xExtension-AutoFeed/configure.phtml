<script>
function testSidecar() {
	var url = document.getElementById('sidecar_url').value.replace(/\/+$/, '') + '/health';
	var status = document.getElementById('sidecar-status');
	status.textContent = '⏳ Testing...';
	status.style.color = '';

	fetch(url, {mode: 'cors'})
		.then(function(r) { return r.json(); })
		.then(function(data) {
			if (data && data.status === 'ok') {
				status.textContent = '✅ Connected (v' + (data.version || '?') + ')';
				status.style.color = 'green';
			} else {
				status.textContent = '⚠️ Unexpected response';
				status.style.color = 'orange';
			}
		})
		.catch(function(err) {
			status.textContent = '❌ Failed: ' + err.message;
			status.style.color = 'red';
		});
}

function testSftp() {
	var host = document.getElementById('sftp_host').value;
	var port = document.getElementById('sftp_port').value || '22';
	var user = document.getElementById('sftp_user').value;
	var keyPath = document.getElementById('sftp_key_path').value;
	var targetDir = document.getElementById('sftp_target_dir').value;
	var status = document.getElementById('sftp-status');

	if (!host || !user || !targetDir) {
		status.textContent = '⚠️ Please fill in host, user, and target directory';
		status.style.color = 'orange';
		return;
	}

	status.textContent = '⏳ Testing SFTP connection...';
	status.style.color = '';

	// Get sidecar URL and make request to test SFTP
	var sidecarUrl = document.getElementById('sidecar_url').value.replace(/\/+$/, '');
	fetch(sidecarUrl + '/sftp/test', {
		method: 'POST',
		headers: { 'Content-Type': 'application/json' },
		body: JSON.stringify({
			host: host,
			port: parseInt(port),
			user: user,
			key_path: keyPath,
			target_dir: targetDir,
		}),
	})
		.then(function(r) { return r.json(); })
		.then(function(data) {
			if (data && data.ok) {
				status.textContent = '✅ SFTP connection successful';
				status.style.color = 'green';
			} else {
				status.textContent = '⚠️ ' + (data.error || 'Connection failed');
				status.style.color = 'orange';
			}
		})
		.catch(function(err) {
			status.textContent = '❌ Failed: ' + err.message;
			status.style.color = 'red';
		});
}
</script>
