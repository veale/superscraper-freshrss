/**
 * Guess the best matching key from a list of sample keys.
 */
function _guessKey(array $sampleKeys, array $candidates): string {
	foreach ($candidates as $c) {
		foreach ($sampleKeys as $k) {
			if (strtolower($k) === strtolower($c)) {
				return $k;
			}
		}
	}
	// Partial match.
	foreach ($candidates as $c) {
		foreach ($sampleKeys as $k) {
			if (stripos($k, $c) !== false) {
				return $k;
			}
		}
	}
	return '';
}
